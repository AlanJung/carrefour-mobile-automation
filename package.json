{
  "name": "carrefour-mobile-automation",
  "version": "1.0.0",
  "description": "Automação de testes mobile — native-demo-app com WebdriverIO + Appium",
  "scripts": {
    "test:android": "wdio run config/wdio.android.conf.js",
    "test:ios": "wdio run config/wdio.ios.conf.js",
    "test:browserstack:android": "wdio run config/wdio.browserstack.android.conf.js",
    "test:browserstack:ios": "wdio run config/wdio.browserstack.ios.conf.js",
    "report:generate": "allure generate .allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "devDependencies": {
    "@browserstack/wdio-browserstack-service": "^2.0.2",
    "@wdio/allure-reporter": "^9.15.0",
    "@wdio/appium-service": "^9.27.2",
    "@wdio/cli": "^9.15.0",
    "@wdio/local-runner": "^9.15.0",
    "@wdio/mocha-framework": "^9.15.0",
    "@wdio/spec-reporter": "^9.15.0",
    "allure-commandline": "^2.30.0",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "appium": "^2.17.0",
    "appium-uiautomator2-driver": "^3.9.0"
  }
}
