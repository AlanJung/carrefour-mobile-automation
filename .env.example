# BrowserStack — credenciais e app
# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NÃO é versionado (está no .gitignore).

# Credenciais da conta BrowserStack (App Automate → Settings)
BROWSERSTACK_USER=seu_usuario
BROWSERSTACK_KEY=sua_access_key

# ID do app após upload via API (ex: bs://abc123...)
# Gerado pelo comando de upload do APK — veja o README.
BROWSERSTACK_APP_ID=bs://xxxxxxxxxxxxxxxxxxxx

# (Opcional) App iOS, se for testar em simulador/dispositivo iOS
BROWSERSTACK_IOS_APP_ID=bs://yyyyyyyyyyyyyyyyyyyy
